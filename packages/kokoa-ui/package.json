{
  "name": "kokoa-ui",
  "version": "0.1.0",
  "description": "Kokoa UI — A retro-pixel themed Vue 3 / Nuxt component library with dark mode support",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    },
    "./components": {
      "import": "./dist/runtime/index.mjs",
      "require": "./dist/runtime/index.cjs"
    },
    "./styles": "./dist/runtime/styles/kokoa.scss",
    "./styles/base": "./dist/runtime/styles/base.scss",
    "./styles/variables": "./dist/runtime/styles/variables.scss",
    "./styles/components": "./dist/runtime/styles/components.scss",
    "./styles/tailwind": "./dist/runtime/styles/main.css"
  },
  "main": "./dist/module.cjs",
  "module": "./dist/module.mjs",
  "types": "./dist/types.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev:prepare": "nuxt-module-build prepare"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0",
    "vue": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "nuxt": {
      "optional": true
    }
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.7"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.7",
    "nuxt": "^4.4.4",
    "sass": "^1.99.0",
    "vue": "^3.5.33",
    "vue-tsc": "^3.3.3"
  }
}
